{
    "name": "cover-music-player",
    "displayName": "Cover Music Player",
    "description": "Apple Music player with album artwork for VSCode on macOS",
    "version": "0.0.1",
    "publisher": "yourname",
    "repository": {
        "type": "git",
        "url": "https://github.com/nekro76/cover-music-player.git"
    },
    "engines": {
        "vscode": "^1.75.0"
    },
    "categories": [
        "Other",
        "Media"
    ],
    "activationEvents": [
        "onStartupFinished"
    ],
    "main": "./out/extension.js",
"files": [
        "out",
        "package.json",
        "media/**",
        "src/webview/**",
        "LICENSE",
        "README.md"
    ],
    "contributes": {
        "commands": [
            {
                "command": "coverMusicPlayer.play",
                "title": "Cover Music Player: Play",
                "category": "Cover Music Player"
            },
            {
                "command": "coverMusicPlayer.pause",
                "title": "Cover Music Player: Pause",
                "category": "Cover Music Player"
            },
            {
                "command": "coverMusicPlayer.togglePlayPause",
                "title": "Cover Music Player: Toggle Play/Pause",
                "category": "Cover Music Player"
            },
            {
                "command": "coverMusicPlayer.next",
                "title": "Cover Music Player: Next Track",
                "category": "Cover Music Player"
            },
            {
                "command": "coverMusicPlayer.previous",
                "title": "Cover Music Player: Previous Track",
                "category": "Cover Music Player"
            },
            {
                "command": "coverMusicPlayer.showPanel",
                "title": "Cover Music Player: Show Panel",
                "category": "Cover Music Player"
            },
            {
                "command": "coverMusicPlayer.volumeUp",
                "title": "Cover Music Player: Volume Up",
                "category": "Cover Music Player"
            },
            {
                "command": "coverMusicPlayer.volumeDown",
                "title": "Cover Music Player: Volume Down",
                "category": "Cover Music Player"
            },
            {
                "command": "coverMusicPlayer.toggleShuffle",
                "title": "Cover Music Player: Toggle Shuffle",
                "category": "Cover Music Player"
            },
            {
                "command": "coverMusicPlayer.toggleRepeat",
                "title": "Cover Music Player: Toggle Repeat",
                "category": "Cover Music Player"
            }
        ],
        "keybindings": [
            {
                "command": "coverMusicPlayer.play",
                "key": "cmd+shift+p",
                "mac": "cmd+shift+p",
                "when": "!editorFocus"
            }
        ],
        "configuration": {
            "title": "Cover Music Player",
            "properties": {
                "coverMusicPlayer.showInStatusBar": {
                    "type": "boolean",
                    "default": true,
                    "description": "Show current track in status bar"
                }
            }
        }
    },
    "scripts": {
        "build": "tsc -p .",
        "watch": "tsc -p . --watch",
        "package": "vsce package",
        "test": "jest"
    },
    "devDependencies": {
        "@types/jest": "^30.0.0",
        "@types/node": "^20.0.0",
        "@types/vscode": "^1.75.0",
        "@vscode/vsce": "^3.7.1",
        "jest": "^30.3.0",
        "ts-jest": "^29.4.9",
        "typescript": "^5.0.0"
    }
}
